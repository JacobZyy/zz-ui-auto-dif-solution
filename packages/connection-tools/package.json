{
  "name": "@ui-differ/connection-tools",
  "version": "1.0.0",
  "description": "UI Differ Connection Tools Library",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs"
    }
  },
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "echo \"📦 [Connection Tools] Watching for changes...\" && vite build --watch --mode development",
    "clean": "rm -rf dist",
    "clean:modules": "rm -rf ./node_modules"
  },
  "devDependencies": {
    "vite": "^6.0.1",
    "vite-plugin-dts": "^4.3.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
